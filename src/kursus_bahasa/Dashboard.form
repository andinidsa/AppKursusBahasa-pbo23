                  <SubComponents>
                    <Component class="javax.swing.JTextArea" name="deskripsiAp">
                      <Properties>
                        <Property name="background" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
                          <Color blue="e7" green="ef" red="f5" type="rgb"/>
                        </Property>
                        <Property name="columns" type="int" value="20"/>
                        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                          <Font name="Century Gothic" size="20" style="1"/>
                        </Property>
                        <Property name="foreground" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
                          <Color blue="9c" green="70" red="4f" type="rgb"/>
                        </Property>
                        <Property name="rows" type="int" value="5"/>
                        <Property name="text" type="java.lang.String" value="     CDI adalah aplikasi berbasis dekstop untuk kursus bahasa yang terdiri dari, bahasa&#xa; Inggris, Jepang, Korea. Yang nantinya proses pembelajaran dilakukan selama 6 bulan. &#xa;Aplikasi desktop kursus bahasa ini dirancang dengan fitur yang terstruktur. Aplikasi ini &#xa;memiliki formulir bahasa yang memudahkan pengguna memilih dan menyesuaikan &#xa;preferens bahasa sesuai kebutuhan mereka. &#xa;     Selain itu, fitur jadwal yang terintegrasi di aplikasi ini memungkinkan admin dapat &#xa;melihat dan merencanakan jadwal kursus mereka (anggota)dengan mudah. Profil dan&#xa;kualifikasi tutor dapat diakses dengan cepat, membantu admin memilih tutor yang sesuai&#xa;dengan kebutuhan anggota. Karena proses belajar dilakukan secara tatap muka&#xa;sehingga  memungkinkan anggota kursus bekerja sama dan berinteraksi satu sama lain,&#xa;yang menghasilkan komunitas belajar yang dinamis. &#xa;     Selain itu, ada laporan transaksi yang memudahkan pencatatan transaksi keuangan &#xa;dan&#xa0;pembayaran."/>
                        <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                          <Border info="null"/>
                        </Property>
                        <Property name="caretColor" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
                          <Color blue="e7" green="ef" red="f5" type="rgb"/>
                        </Property>
                      </Properties>
                      <Events>
                        <EventHandler event="ancestorAdded" listener="javax.swing.event.AncestorListener" parameters="javax.swing.event.AncestorEvent" handler="deskripsiApAncestorAdded"/>
                      </Events>
                    </Component>
                  </SubComponents>
                </Container>
